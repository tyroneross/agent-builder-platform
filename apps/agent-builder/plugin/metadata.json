{
  "name": "agent-builder",
  "displayName": "Agent Builder Plugin Companion",
  "version": "0.4.0",
  "description": "Standalone companion skill for designing, evaluating, building, packaging, and deploying agentic harnesses, skills, and plugins without installing the Agent Builder app.",
  "productRole": "plugin-companion",
  "companionFor": {
    "name": "Agent Builder App",
    "repository": "https://github.com/tyroneross/agent-builder"
  },
  "entrypoint": "SKILL.md",
  "manifests": {
    "claude": ".claude-plugin/plugin.json",
    "codex": ".codex-plugin/plugin.json"
  },
  "standalone": true,
  "bundledWithAppRepository": true,
  "requiredPaths": [
    "SKILL.md",
    "README.md",
    "examples",
    "references",
    "references/catalog/07-local-operational-patterns.md",
    "references/catalog/08-repo-skill-architecture.md",
    "references/catalog/09-skill-bank-and-chaining.md",
    "references/catalog/10-cross-host-deployment.md",
    "references/templates/agentic-handoff/skill-contract.md",
    "references/build/01-build-skill-or-plugin.md",
    "references/build/02-dual-format-parity.md",
    "references/build/03-polyglot-script-guide.md",
    "references/build/04-research-first-protocol.md",
    "references/templates/build/README.md",
    "references/templates/build/SKILL.md.template",
    "references/templates/build/AGENTS.md.template",
    "references/templates/build/plugin.json.template",
    "references/templates/build/parity-checklist.md",
    "references/scripts/scaffold_skill.py",
    ".claude-plugin/plugin.json",
    ".codex-plugin/plugin.json"
  ],
  "excludedAppPaths": [
    "app",
    "lib",
    "scripts",
    "sandbox",
    "tests",
    "generated",
    "agent-outputs",
    "node_modules"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Tyrone Ross",
    "github": "tyroneross"
  }
}
